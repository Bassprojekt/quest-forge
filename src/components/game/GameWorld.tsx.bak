      ))}
      {/* Wegweiser-Laternen */}
      {[
        [15, 0, 0], [-15, 0, 0], [0, 0, 15], [0, 0, -15],
      ].map(([x, , z], i) => (
        <group key={`lamp-${i}`} position={[x, 0, z]}>
          <mesh position={[0, 1.5, 0]} castShadow>
            <cylinderGeometry args={[0.08, 0.1, 3, 8]} />
            <meshStandardMaterial color="#4A4A4A" metalness={0.6} roughness={0.4} />
          </mesh>
          <mesh position={[0, 3.2, 0]}>
            <sphereGeometry args={[0.25, 12, 12]} />
            <meshStandardMaterial color="#FFFACD" emissive="#FFD700" emissiveIntensity={0.8} transparent opacity={0.9} />
          </mesh>
          <pointLight position={[0, 3.2, 0]} color="#FFD700" intensity={1} distance={8} />
        </group>
      ))}
      {/* Zufällige Bäume */}
      {treePositions.map((item, i) => (
