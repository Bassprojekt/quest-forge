const CrystalHighlandsWorld = () => {
  const crystalPositions = useMemo(() => generateScaledPositions(20, 60, 6000), []);
  
  return (
    <group>
      {/* Einzelne große Kristalle */}
      {[
        [25, 0, 20], [-30, 0, 25], [35, 0, -15], [-35, 0, -20], [20, 0, -30],
        [-25, 0, 30], [40, 0, 25], [-40, 0, -25], [30, 0, 35], [-30, 0, -35],
      ].map(([x, , z], i) => (
        <group key={`crystal-${i}`} position={[x, 0, z]} rotation={[0, i * 0.6, 0.1 + (i % 3) * 0.05]}>
          <mesh position={[0, 2 + i * 0.3, 0]} castShadow>
            <octahedronGeometry args={[1.2 + (i % 4) * 0.3, 1]} />
            <meshStandardMaterial
              color={['#00E5FF', '#E040FB', '#00BFA5', '#448AFF', '#FFD700'][i % 5]}
              emissive={['#00E5FF', '#E040FB', '#00BFA5', '#448AFF', '#FFD700'][i % 5]}
              emissiveIntensity={0.6}
              metalness={0.85}
              roughness={0.08}
              transparent
              opacity={0.85}
            />
          </mesh>
          <mesh position={[0.3, 1 + i * 0.2, 0.2]} castShadow>
            <octahedronGeometry args={[0.6, 0]} />
            <meshStandardMaterial
              color={['#00E5FF', '#E040FB', '#00BFA5'][i % 3]}
              emissive={['#00E5FF', '#E040FB', '#00BFA5'][i % 3]}
              emissiveIntensity={0.4}
              metalness={0.9}
              roughness={0.1}
            />
          </mesh>
          <pointLight position={[0, 2.5, 0]} color={['#00E5FF', '#E040FB', '#00BFA5', '#448AFF'][i % 4]} intensity={1.5} distance={8} />
        </group>
      ))}
      {/* Kristall-Säulen */}
      {[
        [50, 0, 40], [-55, 0, 45], [55, 0, -35], [-50, 0, -40],
      ].map(([x, , z], i) => (
        <group key={`bigcrystal-${i}`} position={[x, 0, z]}>
          <mesh position={[0, 4, 0]} castShadow>
            <cylinderGeometry args={[0.5, 0.8, 8, 8]} />
            <meshStandardMaterial color="#B8D8E8" metalness={0.7} roughness={0.2} />
          </mesh>
          <mesh position={[0, 8.5, 0]} castShadow>
            <octahedronGeometry args={[1, 0]} />
            <meshStandardMaterial color="#FFFFFF" emissive="#E0F7FA" emissiveIntensity={0.3} metalness={0.9} roughness={0.1} />
          </mesh>
        </group>
      ))}
      {/* Zufällige kleine Kristalle */}
      {crystalPositions.map((item, i) => (
        <Crystal key={`crystal-random-${i}`} position={item.pos} />
      ))}
      {/* Funkelnde Partikel am Boden */}
      {Array.from({ length: 30 }, (_, i) => (
        <mesh key={`sparkle-${i}`} position={[(Math.random() - 0.5) * 80, 0.1, (Math.random() - 0.5) * 80]}>
          <sphereGeometry args={[0.08, 6, 6]} />
          <meshStandardMaterial color="#FFFFFF" emissive="#FFFFFF" emissiveIntensity={1.5} transparent opacity={0.7} />
      </mesh>
    ))}
    <ReturnPortal />
  </group>
);

const VoidNexusWorld = () => {
  return (
    <group>
      <mesh rotation={[-Math.PI / 2, 0, 0]} position={[0, -0.01, 0]} receiveShadow>
        <planeGeometry args={[200, 200]} />
        <meshStandardMaterial color="#1A0A2A" />
      </mesh>
      {/* Void-Portale */}
      {[
        [40, 0, 35], [-45, 0, 40], [50, 0, -30], [-50, 0, -35], [35, 0, -45],
        [-40, 0, 30], [55, 0, 20], [-55, 0, -20],
      ].map(([x, , z], i) => (
        <group key={`obelisk-${i}`} position={[x, 0, z]}>
        <mesh position={[0, 4, 0]} castShadow>
          <boxGeometry args={[0.6, 8, 0.6]} />
          <meshStandardMaterial color="#2A1A3A" emissive="#4A148C" emissiveIntensity={0.6} metalness={0.5} roughness={0.3} />
        </mesh>
        <mesh position={[0, 8.5, 0]} castShadow>
          <torusGeometry args={[0.8, 0.15, 8, 16]} />
          <meshStandardMaterial color="#7B1FA2" emissive="#7B1FA2" emissiveIntensity={1.5} metalness={0.8} roughness={0.2} />
        </mesh>
        <mesh position={[0, 8.5, 0]}>
          <circleGeometry args={[0.6, 16]} />
          <meshStandardMaterial color="#4A148C" emissive="#7B1FA2" emissiveIntensity={1} transparent opacity={0.5} side={THREE.DoubleSide} />
        </mesh>
        <pointLight position={[0, 8, 0]} color="#7B1FA2" intensity={3} distance={12} />
      </group>
    ))}
    {/* Schwebende Void-Kugeln */}
    {Array.from({ length: 30 }, (_, i) => (
      <mesh key={`void-${i}`} position={[(Math.random() - 0.5) * 90, 2 + Math.random() * 10, (Math.random() - 0.5) * 90]}>
        <sphereGeometry args={[0.4 + Math.random() * 0.5, 10, 10]} />
        <meshStandardMaterial
          color="#7B1FA2"
          emissive="#7B1FA2"
          emissiveIntensity={2.5}
          transparent
          opacity={0.45}
        />
      </mesh>
    ))}
    {/* Void-Blumen (unheimlich) */}
    {[
      [20, 0, 15], [-25, 0, 20], [30, 0, -20], [-15, 0, -25], [25, 0, 25], [-30, 0, 10],
    ].map(([x, , z], i) => (
      <group key={`voidflower-${i}`} position={[x, 0, z]}>
        <mesh position={[0, 0.8, 0]} castShadow>
          <cylinderGeometry args={[0.05, 0.08, 1.6, 6]} />
          <meshStandardMaterial color="#1A1A2A" roughness={0.9} />
        </mesh>
        <mesh position={[0, 1.7, 0]}>
          <sphereGeometry args={[0.2, 10, 8]} />
          <meshStandardMaterial color={['#7B1FA2', '#4A148C', '#9C27B0', '#E040FB'][i % 4]} emissive={['#7B1FA2', '#4A148C', '#9C27B0', '#E040FB'][i % 4]} emissiveIntensity={0.8} transparent opacity={0.7} />
        </mesh>
        <pointLight position={[0, 1.7, 0]} color={['#7B1FA2', '#4A148C', '#9C27B0', '#E040FB'][i % 4]} intensity={0.5} distance={4} />
      </group>
    ))}
    {/* Risse im Boden */}
    {Array.from({ length: 15 }, (_, i) => (
      <mesh key={`crack-${i}`} rotation={[-Math.PI / 2, 0, Math.random() * Math.PI]} position={[(Math.random() - 0.5) * 70, 0.01, (Math.random() - 0.5) * 70]}>
        <planeGeometry args={[2 + Math.random() * 3, 0.3]} />
        <meshStandardMaterial color="#0A0010" transparent opacity={0.8} />
      </mesh>
    ))}
    <ReturnPortal />
  </group>
);

const MushroomForestWorld = () => {
  const bushPositions = useMemo(() => generateScaledPositions(30, 60, 1000), []);
  const rockPositions = useMemo(() => generateScaledPositions(20, 50, 2000), []);
  const flowerPositions = useMemo(() => generateScaledPositions(40, 60, 3000), []);
  const treePositions = useMemo(() => generateScaledPositions(10, 50, 4000), []);
  const mushroomTreePositions = useMemo(() => generateScaledPositions(15, 60, 5000), []);
  
  return (
    <group>
      {/* Pilz-Bäume (einzigartig für Pilzwald) */}
      {mushroomTreePositions.map((item, i) => (
        <MushroomTree key={`mushroom-tree-${i}`} position={item.pos} scale={item.scale} />
      ))}
      {/* Hügel im Hintergrund */}
      {[
        [60, 0, 40], [-70, 0, 60], [80, 0, -30], [-60, 0, -50], [40, 0, 80], [-40, 0, -80],
      ].map(([x, , z], i) => (
        <Hill key={`hill-${i}`} position={[x, 0, z]} scale={1.5 + (i % 3) * 0.5} />
      ))}
      {/* Große Bäume */}
      {[
        [25, 0, 25], [-20, 0, 18], [30, 0, -15], [-28, 0, -25], [15, 0, -30],
        [-35, 0, 8], [40, 0, 5], [-12, 0, 35], [35, 0, 28], [-30, 0, -12],
        [50, 0, -20], [-45, 0, 25], [20, 0, 45], [-55, 0, -15], [45, 0, 35],
      ].map(([x, , z], i) => (
        <group key={`tree-${i}`} position={[x, 0, z]}>
          <mesh position={[0, 2, 0]} castShadow>
            <cylinderGeometry args={[0.4, 0.5, 4, 10]} />
            <meshStandardMaterial color="#8B6914" roughness={0.9} />
          </mesh>
          <mesh position={[0, 4.5, 0]} castShadow>
            <sphereGeometry args={[2, 12, 12]} />
            <meshStandardMaterial color="#228B22" roughness={0.8} />
          </mesh>
        </group>
      ))}
      {/* Büsche */}
      {bushPositions.map((item, i) => (
        <Bush key={`bush-${i}`} position={item.pos} scale={item.scale} />
      ))}
      {/* Felsen */}
      {rockPositions.map((item, i) => (
        <Rock key={`rock-${i}`} position={item.pos} scale={item.scale} />
      ))}
      {/* Teiche */}
      {[
        [35, 0, -35], [-40, 0, 30], [50, 0, 50], [-55, 0, -40],
      ].map(([x, , z], i) => (
        <Pond key={`pond-${i}`} position={[x, 0, z]} />
      ))}
      {/* Blumenwiesen */}
      {flowerPositions.map((item, i) => (
        <Flower key={`flower-${i}`} position={item.pos} color={['#FF69B4', '#FFD700', '#FF6347', '#FF1493', '#DA70D6', '#FFA500'][i % 6]} scale={0.6 + (i % 4) * 0.1} />
      ))}
      {/* Wegweiser-Laternen */}
      {[
        [15, 0, 0], [-15, 0, 0], [0, 0, 15], [0, 0, -15],
      ].map(([x, , z], i) => (
        <group key={`lamp-${i}`} position={[x, 0, z]}>
          <mesh position={[0, 1.5, 0]} castShadow>
            <cylinderGeometry args={[0.08, 0.1, 3, 8]} />
            <meshStandardMaterial color="#4A4A4A" metalness={0.6} roughness={0.4} />
          </mesh>
          <mesh position={[0, 3.2, 0]}>
            <sphereGeometry args={[0.25, 12, 12]} />
            <meshStandardMaterial color="#FFFACD" emissive="#FFD700" emissiveIntensity={0.8} transparent opacity={0.9} />
          </mesh>
          <pointLight position={[0, 3.2, 0]} color="#FFD700" intensity={1} distance={8} />
        </group>
      ))}
      {/* Zufällige Bäume */}
      {treePositions.map((item, i) => (
        <group key={`random-tree-${i}`} position={[item.pos[0], item.pos[1], item.pos[2]]}>
          <mesh position={[0, 1.5 * item.scale, 0]} castShadow>
            <cylinderGeometry args={[0.2 * item.scale, 0.3 * item.scale, 3 * item.scale, 8]} />
            <meshStandardMaterial color="#8B6914" roughness={0.9} />
          </mesh>
          <mesh position={[0, 3 * item.scale, 0]} castShadow>
            <sphereGeometry args={[1.2 * item.scale, 12, 12]} />
            <meshStandardMaterial color={['#228B22', '#32CD32', '#3CB371', '#2E8B57'][i % 4]} />
          </mesh>
        </group>
      ))}
      <ReturnPortal />
    </group>
  );
};

const GrasslandsWorld = () => {
