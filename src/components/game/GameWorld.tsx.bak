import * as THREE from 'three';
import React, { useMemo } from 'react';
import { useGameStore, ZoneType, ZONES } from '@/store/gameStore';

interface WorldTheme {
  groundColor: string;
  groundColor2?: string;
  skyColor: string;
}

const WORLD_THEMES: Record<string, WorldTheme> = {
  grasslands: { groundColor: '#6DBE6D', skyColor: '#7EC8E3' },
  mushroom_forest: { groundColor: '#4A6B4A', skyColor: '#6B4A8B' },
  frozen_peaks: { groundColor: '#D8E8F0', skyColor: '#A8D8EA' },
  lava_caverns: { groundColor: '#4A3030', skyColor: '#FF6B35' },
  coral_reef: { groundColor: '#5BA8A0', skyColor: '#40C4FF' },
  shadow_swamp: { groundColor: '#3A4A3A', skyColor: '#4A5A5A' },
  crystal_highlands: { groundColor: '#B8D0E0', skyColor: '#E0F0FF' },
  void_nexus: { groundColor: '#1A0A2A', skyColor: '#2A0A4A' },
};

const seededRandom = (seed: number) => {
  const x = Math.sin(seed * 9999) * 10000;
  return x - Math.floor(x);
};

const generatePositions = (count: number, range: number, seedBase: number): [number, number, number][] => {
  const positions: [number, number, number][] = [];
  for (let i = 0; i < count; i++) {
    const seed = seedBase + i * 123.456;
    positions.push([
      (seededRandom(seed) - 0.5) * range,
      0,
      (seededRandom(seed + 789) - 0.5) * range,
    ]);
  }
  return positions;
};

const generateScaledPositions = (count: number, range: number, seedBase: number): { pos: [number, number, number]; scale: number }[] => {
  const results: { pos: [number, number, number]; scale: number }[] = [];
  for (let i = 0; i < count; i++) {
    const seed = seedBase + i * 456.789;
    results.push({
      pos: [
        (seededRandom(seed) - 0.5) * range,
        0,
        (seededRandom(seed + 321) - 0.5) * range,
      ],
      scale: 0.5 + seededRandom(seed + 654) * 0.5,
    });
  }
  return results;
};

const ReturnPortal = () => {
  const setPlayerPosition = useGameStore(s => s.setPlayerPosition);
  return (
    <group position={[0, 0, -5]} onClick={() => setPlayerPosition([0, 0, 0])}>
      <mesh position={[0, 0.15, 0]} castShadow>
        <cylinderGeometry args={[2, 2.5, 0.3, 16]} />
        <meshStandardMaterial color="#D2B48C" roughness={0.5} />
      </mesh>
      <mesh position={[0, 2, 0]}>
        <torusGeometry args={[1.5, 0.12, 12, 24]} />
        <meshStandardMaterial color="#FFD700" emissive="#FFD700" emissiveIntensity={1.5} metalness={0.7} roughness={0.2} />
      </mesh>
      <mesh position={[0, 2, 0]}>
        <circleGeometry args={[1.3, 24]} />
        <meshStandardMaterial color="#FFD700" emissive="#FFE082" emissiveIntensity={0.5} transparent opacity={0.3} side={THREE.DoubleSide} />
      </mesh>
      <pointLight position={[0, 2, 0]} color="#FFD700" intensity={3} distance={8} />
    </group>
  );
};

